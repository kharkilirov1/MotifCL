Checks: >
  clang-diagnostic-*,
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  portability-*,
  readability-identifier-naming
WarningsAsErrors: ''
HeaderFilterRegex: '^(include|src|tests|examples|tools)/'
CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case

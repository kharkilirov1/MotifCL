class Parameter:
    def __init__(self, tensor: Tensor, trainable: bool = True) -> None: ...
    data: Tensor
    trainable: bool
    def grad(self) -> Tensor: ...
    def zero_grad(self) -> None: ...


class Module:
    def forward(self, x: Tensor) -> Tensor: ...
    def zero_grad(self) -> None: ...


class Linear(Module):
    def __init__(self, backend: Backend, in_features: int, out_features: int, bias: bool = True) -> None: ...
    weight: Parameter
    bias: Parameter
    def parameters(self) -> list[Parameter]: ...
    def has_bias(self) -> bool: ...
    def enable_quantized_inference(self, qdtype: DType = DType.Q4_0) -> None: ...
    def set_quantized_weight(self, weight: Tensor) -> None: ...
    def disable_quantized_inference(self) -> None: ...
    def quantized_inference_enabled(self) -> bool: ...
    def quantized_weight_dtype(self) -> DType: ...
    def quantized_weight(self) -> Tensor: ...


class QuantizedLinear(Module):
    def __init__(self, weight: Tensor, bias_or_qdtype: object = ..., qdtype: DType = DType.Q4_0) -> None: ...
    @staticmethod
    def from_linear(linear: Linear, qdtype: DType = DType.Q4_0) -> QuantizedLinear: ...
    def parameters(self) -> list[Parameter]: ...
    def quantized_weight(self) -> Tensor: ...
    def bias(self) -> Tensor: ...
    def has_bias(self) -> bool: ...
    def weight_dtype(self) -> DType: ...
    def in_features(self) -> int: ...
    def out_features(self) -> int: ...


class GELU(Module): ...


class Sequential(Module):

    def profile_summary(self) -> list[ProfileSummary]: ...


class Tensor:
    @property
    def shape(self) -> list[int]: ...
    @property
    def dtype(self) -> DType: ...
    @property
    def requires_grad(self) -> bool: ...
    def id(self) -> int: ...
    def cpu(self) -> list[float]: ...
    def cpu_i32(self) -> list[int]: ...
    def item(self) -> float: ...
    def backward(self) -> None: ...
    def set_requires_grad(self, value: bool = True) -> None: ...
    def view(self, shape: Sequence[int]) -> Tensor: ...
    def __add__(self, other: Tensor) -> Tensor: ...
    def __radd__(self, other: Tensor) -> Tensor: ...
    def __sub__(self, other: Tensor) -> Tensor: ...
    def __rsub__(self, other: Tensor) -> Tensor: ...
    def __mul__(self, other: Tensor | float | int) -> Tensor: ...
    def __rmul__(self, other: Tensor | float | int) -> Tensor: ...
    def __matmul__(self, other: Tensor) -> Tensor: ...
    def __neg__(self) -> Tensor: ...



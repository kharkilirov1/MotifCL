{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Developer build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MOTIFCL_BUILD_TESTS": "ON",
        "MOTIFCL_BUILD_EXAMPLES": "ON",
        "MOTIFCL_BUILD_TOOLS": "ON",
        "MOTIFCL_BUILD_BENCHMARKS": "OFF",
        "MOTIFCL_BUILD_PYTHON": "OFF",
        "MOTIFCL_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MOTIFCL_BUILD_TESTS": "ON",
        "MOTIFCL_BUILD_EXAMPLES": "ON",
        "MOTIFCL_BUILD_TOOLS": "ON",
        "MOTIFCL_BUILD_BENCHMARKS": "ON",
        "MOTIFCL_BUILD_PYTHON": "OFF",
        "MOTIFCL_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "python",
      "displayName": "Python extension build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/python",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MOTIFCL_BUILD_TESTS": "OFF",
        "MOTIFCL_BUILD_EXAMPLES": "OFF",
        "MOTIFCL_BUILD_TOOLS": "OFF",
        "MOTIFCL_BUILD_BENCHMARKS": "OFF",
        "MOTIFCL_BUILD_PYTHON": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "python",
      "configurePreset": "python"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
